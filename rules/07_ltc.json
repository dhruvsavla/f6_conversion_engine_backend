{
  "transaction_type": "LTC",
  "description": "Long-term care pharmacy claim",
  "detection": {
    "transaction_code": [
      "B1",
      "01"
    ],
    "patient_residence": [
      "03",
      "06",
      "09",
      "31",
      "32",
      "33"
    ]
  },
  "segments": {
    "HDR": [
      {
        "field_id": "101-A1",
        "field_name": "BIN / IIN Number",
        "action": "transform",
        "transform": "ZERO_PAD_LEFT",
        "params": {
          "length": 8
        }
      },
      {
        "field_id": "102-A2",
        "field_name": "Version / Release Number",
        "action": "transform",
        "transform": "SET_VALUE",
        "value": "F6"
      },
      {
        "field_id": "103-A3",
        "field_name": "Transaction Code",
        "action": "carry"
      },
      {
        "field_id": "104-A4",
        "field_name": "Processor Control Number",
        "action": "carry"
      },
      {
        "field_id": "109-A9",
        "field_name": "Transaction Count",
        "action": "carry"
      },
      {
        "field_id": "201-B1",
        "field_name": "Service Provider ID",
        "action": "carry"
      },
      {
        "field_id": "202-B2",
        "field_name": "Service Provider ID Qualifier",
        "action": "carry"
      },
      {
        "field_id": "401-D1",
        "field_name": "Date of Service",
        "action": "carry"
      }
    ],
    "INS": [
      {
        "field_id": "302-C2",
        "field_name": "Cardholder ID",
        "action": "carry"
      },
      {
        "field_id": "301-C1",
        "field_name": "Group ID",
        "action": "carry"
      },
      {
        "field_id": "306-C6",
        "field_name": "Patient Relationship Code",
        "action": "carry"
      },
      {
        "field_id": "990-MG",
        "field_name": "Legacy Routing Code",
        "action": "remove"
      },
      {
        "field_id": "367-2N",
        "field_name": "Benefit Network Indicator",
        "action": "add",
        "default_value": "",
        "warn_if_empty": true,
        "warn_code": "BNI",
        "warn_severity": "WARN",
        "warn_message": "Benefit Network Indicator (367-2N) required in F6."
      }
    ],
    "PAT": [
      {
        "field_id": "304-C4",
        "field_name": "Date of Birth",
        "action": "carry"
      },
      {
        "field_id": "305-C5",
        "field_name": "Patient Gender Code",
        "action": "carry"
      },
      {
        "field_id": "310-CA",
        "field_name": "Patient First Name",
        "action": "carry"
      },
      {
        "field_id": "311-CB",
        "field_name": "Patient Last Name",
        "action": "carry"
      },
      {
        "field_id": "384-7E",
        "field_name": "Patient Residence",
        "action": "carry",
        "notes": "Patient residence determines LTC claim type."
      }
    ],
    "CLM": [
      {
        "field_id": "455-EM",
        "field_name": "Rx Reference Number Qualifier",
        "action": "carry"
      },
      {
        "field_id": "402-D2",
        "field_name": "Rx Reference Number",
        "action": "carry"
      },
      {
        "field_id": "436-E1",
        "field_name": "Product / Service ID Qualifier",
        "action": "carry"
      },
      {
        "field_id": "407-D7",
        "field_name": "Product / Service ID",
        "action": "carry"
      },
      {
        "field_id": "442-E7",
        "field_name": "Quantity Dispensed",
        "action": "carry"
      },
      {
        "field_id": "403-D3",
        "field_name": "Fill Number",
        "action": "carry"
      },
      {
        "field_id": "405-D5",
        "field_name": "Days Supply",
        "action": "carry"
      },
      {
        "field_id": "406-D6",
        "field_name": "Compound Code",
        "action": "carry"
      },
      {
        "field_id": "408-D8",
        "field_name": "Dispense As Written Code",
        "action": "carry"
      },
      {
        "field_id": "414-DE",
        "field_name": "Date Prescription Written",
        "action": "carry"
      },
      {
        "field_id": "419-DJ",
        "field_name": "Number of Refills Authorized",
        "action": "carry"
      },
      {
        "field_id": "147-U7",
        "field_name": "Pharmacy Service Type",
        "action": "add",
        "default_value": "05",
        "warn_if_empty": true,
        "warn_code": "PST",
        "warn_severity": "WARN",
        "warn_message": "Pharmacy Service Type (147-U7) mandatory in F6."
      },
      {
        "field_id": "418-DI",
        "field_name": "Quantity Prescribed",
        "action": "add",
        "default_value": "",
        "warn_if_empty": true,
        "warn_code": "QP",
        "warn_severity": "WARN",
        "warn_message": "Quantity Prescribed (418-DI) mandatory in F6."
      },
      {
        "field_id": "C90-KH",
        "field_name": "LTPAC Billing Methodology",
        "action": "add",
        "default_value": "",
        "notes": "NEW IN F6. 1=Full qty on date dispensed, 2=Post-consumption (monthly), 3=Pre-consumption."
      },
      {
        "field_id": "C92-KM",
        "field_name": "Number of LTPAC Dispensing Events",
        "action": "add",
        "default_value": "",
        "notes": "NEW IN F6. Count of dispensing events comprising the claim."
      },
      {
        "field_id": "C91-KK",
        "field_name": "LTPAC Dispense Frequency",
        "action": "add",
        "default_value": "",
        "notes": "NEW IN F6. Interval pattern of dispensing/resupply."
      }
    ],
    "PRE": [
      {
        "field_id": "466-EZ",
        "field_name": "Prescriber ID Qualifier",
        "action": "carry"
      },
      {
        "field_id": "411-DB",
        "field_name": "Prescriber ID (NPI)",
        "action": "carry"
      },
      {
        "field_id": "427-DR",
        "field_name": "Prescriber Last Name",
        "action": "carry"
      },
      {
        "field_id": "364-2J",
        "field_name": "Prescriber First Name",
        "action": "add",
        "default_value": "",
        "warn_if_empty": true,
        "warn_code": "PFN",
        "warn_severity": "WARN",
        "warn_message": "Prescriber First Name (364-2J) empty."
      }
    ],
    "FAC": [
      {
        "field_id": "336-8C",
        "field_name": "Facility Name",
        "action": "carry"
      },
      {
        "field_id": "332-CY",
        "field_name": "Facility Street Address",
        "action": "carry"
      },
      {
        "field_id": "333-CZ",
        "field_name": "Facility City",
        "action": "carry"
      },
      {
        "field_id": "334-HN",
        "field_name": "Facility State",
        "action": "carry"
      },
      {
        "field_id": "335-2C",
        "field_name": "Facility Zip Code",
        "action": "carry"
      }
    ],
    "PRI": [
      {
        "field_id": "409-D9",
        "field_name": "Patient Pay Amount",
        "action": "carry"
      },
      {
        "field_id": "412-DC",
        "field_name": "Copay / Coinsurance Amount",
        "action": "carry"
      },
      {
        "field_id": "426-DQ",
        "field_name": "Ingredient Cost Submitted",
        "action": "carry"
      },
      {
        "field_id": "430-DU",
        "field_name": "Ingredient Cost Paid",
        "action": "carry"
      },
      {
        "field_id": "423-DN",
        "field_name": "Basis of Cost Determination",
        "action": "carry"
      },
      {
        "field_id": "433-DX",
        "field_name": "Total Amount Paid",
        "action": "carry"
      },
      {
        "field_id": "478-H7",
        "field_name": "Basis of Reimbursement",
        "action": "cases",
        "mandatory_f6": false,
        "notes": "NEW in F6 PRI segment. Maps from D.0 CLM field 423-DN (Basis of Cost Determination). Codes are identical — direct map. If 423-DN is present and non-empty, copy the value. If 423-DN is absent, emit WARN BRD. SOURCE: NCPDP F6 Editorial v02 §3.11 PRI segment field reference.",
        "warn_if_empty": true,
        "warn_code": "BRD",
        "warn_severity": "WARN",
        "warn_message": "Basis of Reimbursement (478-H7) is empty. Could not map from 423-DN (Basis of Cost Determination) — field was absent in the source D.0 transaction.",
        "cases": [
          {
            "when": {
              "operator": "present_and_nonempty",
              "field": "CLM.423-DN"
            },
            "then": {
              "action": "transform",
              "transform": "COPY_FROM_FIELD",
              "source_field": "CLM.423-DN"
            }
          },
          {
            "when": "default",
            "then": {
              "action": "add",
              "default_value": ""
            }
          }
        ]
      }
    ]
  }
}
